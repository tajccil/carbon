# Copy to .env: cp .env.example .env
#
# Session: openssl rand -base64 16
SESSION_SECRET=REPLACE_ME

NODE_ENV=production

# Public HTTPS URLs (your reverse proxy must set X-Forwarded-Proto: https)
DOMAIN=carbon.example.com
ERP_URL=https://carbon.example.com
MES_URL=https://carbon.example.com
VERCEL_URL=https://carbon.example.com

POSTHOG_API_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_PUBLIC_KEY=phc_your_project_key

# --- Outbound email (verification codes, invites via sendEmail) ---
# Prefer SMTP on self-hosted; otherwise set RESEND_API_KEY + RESEND_DOMAIN.
APP_NAME=Carbon
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Carbon

RESEND_API_KEY=
RESEND_DOMAIN=
DISABLE_RESEND=
DISABLE_EMAIL=

# Postgres (docker-compose service `postgres`)
POSTGRES_USER=carbon
POSTGRES_PASSWORD=REPLACE_STRONG_PASSWORD
POSTGRES_DB=carbon

# Direct SQL (Kysely). If using compose postgres: use same password as above.
SUPABASE_DB_URL=postgresql://carbon:REPLACE_STRONG_PASSWORD@postgres:5432/carbon

# Supabase HTTP API (required). If Supabase runs on host: http://host.docker.internal:54321
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (Upstash REST — required for login / @carbon/kv)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Trigger.dev (optional — for background jobs)
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_PROJECT_ID=

AUTH_PROVIDERS=email,google
CARBON_EDITION=community
NOVU_APPLICATION_ID=
NOVU_SECRET_KEY=
RATE_LIMIT=5
